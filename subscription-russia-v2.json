  "burstObservatory": {
    "subjectSelector": ["ru", "eu", "ai"],
    "pingConfig": {
      "destination": "http://www.gstatic.com/generate_204",
      "connectivity": "",
      "interval": "30s",
      "timeout": "2s",
      "sampling": 2
    }
  }
